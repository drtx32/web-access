# web-access skill 用户偏好配置
# 此文件是模板。首次运行 check-deps.mjs 时会自动复制为 config.env（git ignored）。
#
# 用户长期偏好的默认 Agent 浏览器
# - 留空：每次启动都问用户偏好哪个
# - 设值：固定使用该浏览器；若未检测到对应 toggle 则硬错（不擅自降级）
#
# 合法值：chrome / edge
WEB_ACCESS_BROWSER=

# 直接连接一个已知 CDP discovery / websocket URL
# 典型场景：CloakBrowser Manager MCP 启动 profile 后返回的 cdp_url
# 例如：http://127.0.0.1:5100/json/list
WEB_ACCESS_CDP_URL=

# 手动远程调试端口兜底候选
# - 留空：使用默认候选端口段（见 browser-discovery.mjs）
# - 设值：逗号分隔的端口或范围，例如 9222-9235,9333-9345
WEB_ACCESS_FALLBACK_PORTS=
